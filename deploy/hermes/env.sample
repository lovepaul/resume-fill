TELEGRAM_BOT_TOKEN=replace_with_real_token
TELEGRAM_ALLOWED_USERS=6218536294
TELEGRAM_CUSTOM_MENU=true
HERMES_YOLO_MODE=1

# 可选：固定发件箱（himalaya config.toml 对应账号）
RESUME_BOT_SENDER=lensman.lucas@gmail.com

# 可选：skill 专用虚拟环境路径（默认: <skill目录>/.venv）
RESUME_BOT_VENV_PATH=

# 可选：DeepSeek 配置（推荐使用 init-llm 写入 BOT_CONFIG）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
